// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Build forced at: 2026-05-09T12:53:00

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS - PLATAFORMA (GLOBAL)
// ─────────────────────────────────────────────────────────────

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

enum TenantStatus {
  TRIAL
  ACTIVE
  OVERDUE
  SUSPENDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

// ─────────────────────────────────────────────────────────────
// ENUMS - TENANT (OPERAÇÃO)
// ─────────────────────────────────────────────────────────────

enum TenantUserRole {
  TENANT_ADMIN
  GERENTE
  OPERADOR
  FINANCEIRO
}

enum TransactionType {
  CREDIT
  DEBIT
  REVERSAL
  WITHDRAWAL
  ADJUSTMENT
}

enum FinancialReferenceType {
  SALE
  PAYOUT
  SETTLEMENT
  ADJUSTMENT
  MANUAL
}

// ─────────────────────────────────────────────────────────────
// MÓDULO 1: PLATAFORMA SaaS (GLOBAL)
// ─────────────────────────────────────────────────────────────

model PlatformAdmin {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  role         PlatformRole @default(SUPPORT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  auditLogs PlatformAuditLog[]

  @@map("platform_admins")
}

model Tenant {
  id                 String       @id @default(uuid())
  companyName        String
  slug               String       @unique
  document           String? // CPF or CNPJ
  email              String       @unique
  phone              String?
  status             TenantStatus @default(TRIAL)
  subscriptionStatus String       @default("active")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // SaaS Relations
  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]

  // Operations Relations
  users                  User[]
  categories             Category[]
  products               Product[]
  pointsOfSale           POS[]
  consignmentLots        ConsignmentLot[]
  sales                  Sale[]
  consignmentSettlements ConsignmentSettlement[]
  operationLogs          OperationLog[]
  transactions           FinancialTransaction[]
  consignorAccount       ConsignorAccount?
  whatsappConfig         WhatsAppConfig?
  stockSnapshots         StockSnapshot[]

  @@map("tenants")
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(12, 2)
  maxUsers     Int      @default(5)
  maxPos       Int      @default(2)
  maxProducts  Int      @default(100)
  featuresJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                  String    @id @default(uuid())
  tenantId            String
  planId              String
  status              String    @default("active")
  startDate           DateTime  @default(now())
  endDate             DateTime?
  renewalDate         DateTime?
  asaasSubscriptionId String? // ID da assinatura no Asaas
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  payments Payment[]
  invoices Invoice[]

  @@map("subscriptions")
}

model Payment {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String
  amount         Decimal       @db.Decimal(12, 2)
  method         String
  gateway        String        @default("asaas")
  status         PaymentStatus @default(PENDING)
  externalId     String? // ID no gateway de pagamento
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("platform_payments")
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String
  amount         Decimal       @db.Decimal(12, 2)
  dueDate        DateTime
  status         InvoiceStatus @default(OPEN)
  pdfUrl         String?
  createdAt      DateTime      @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("platform_invoices")
}

model PlatformAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  admin PlatformAdmin @relation(fields: [adminId], references: [id])

  @@map("platform_audit_logs")
}

// ─────────────────────────────────────────────────────────────
// MÓDULO 2: OPERAÇÃO DO TENANT (ISOLADO)
// ─────────────────────────────────────────────────────────────

model User {
  id           String         @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         TenantUserRole @default(OPERADOR)
  isActive     Boolean        @default(true)
  refreshToken String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([tenantId])
  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  categoryId  String?
  sku         String?
  name        String
  description String?
  imageUrl    String?
  unit        String   @default("un")
  barcode     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id])
  consignmentLots ConsignmentLot[]
  saleItems       SaleItem[]
  stockSnapshots  StockSnapshot[]

  @@index([tenantId])
  @@map("products")
}

model POS {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  responsibleName   String?
  document          String?
  whatsapp          String?
  email             String?
  city              String?
  state             String?
  location          String?
  street            String?
  number            String?
  neighborhood      String?
  zipCode           String?
  complement        String?
  defaultCommission Decimal? @db.Decimal(5, 2)
  isActive          Boolean  @default(true)
  openingDate       DateTime?
  billingDay        Int?
  isRecurring       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales                  Sale[]
  stockSnapshots         StockSnapshot[]
  consignmentLots        ConsignmentLot[]
  consignmentSettlements ConsignmentSettlement[]

  @@index([tenantId])
  @@map("points_of_sale")
}

model ConsignmentLot {
  id                String    @id @default(uuid())
  tenantId          String
  posId             String? // Opcional por enquanto, para permitir lotes "globais" ou em trânsito
  productId         String
  quantityReceived  Int
  quantitySold      Int       @default(0)
  quantityReturned  Int       @default(0)
  quantityLost      Int       @default(0)
  unitPrice         Decimal?  @db.Decimal(12, 2)
  commissionPercent Decimal   @db.Decimal(5, 2)
  reference         String?   @db.Text
  notes             String?   @db.Text
  receivedAt        DateTime  @default(now())
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pos       POS?       @relation(fields: [posId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  saleItems SaleItem[]

  @@index([tenantId])
  @@index([posId])
  @@index([productId])
  @@index([receivedAt])
  @@map("consignment_lots")
}

model StockSnapshot {
  id        String   @id @default(uuid())
  tenantId  String
  productId String
  posId     String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  pos     POS     @relation(fields: [posId], references: [id])

  @@unique([tenantId, productId, posId])
  @@index([tenantId])
  @@map("stock_snapshots")
}

model Sale {
  id          String   @id @default(uuid())
  tenantId    String
  posId       String
  totalAmount Decimal  @db.Decimal(12, 2)
  createdBy   String? // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pos    POS        @relation(fields: [posId], references: [id])
  items  SaleItem[]

  @@index([tenantId])
  @@index([posId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id                String   @id @default(uuid())
  tenantId          String
  saleId            String
  productId         String
  consignmentLotId  String
  quantity          Int
  unitPrice         Decimal  @db.Decimal(12, 2)
  commissionPercent Decimal  @db.Decimal(5, 2)
  consignorAmount   Decimal  @db.Decimal(12, 2) // Valor que fica para o consignador (tenant)
  settlementId      String?
  createdAt         DateTime @default(now())

  sale                 Sale                  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product              Product               @relation(fields: [productId], references: [id])
  consignmentLot       ConsignmentLot        @relation(fields: [consignmentLotId], references: [id])
  consignmentSettlement ConsignmentSettlement? @relation(fields: [settlementId], references: [id])

  @@index([tenantId])
  @@map("sale_items")
}

model ConsignorAccount {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("consignor_accounts")
}

model ConsignmentSettlement {
  id              String   @id @default(uuid())
  tenantId        String
  posId           String
  totalAmount     Decimal  @db.Decimal(12, 2) // Total das vendas líquidas neste fechamento
  status          String   @default("PENDING") // PENDING, COMPLETED
  notes           String?
  startDate       DateTime?
  endDate         DateTime?
  settledAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pos       POS        @relation(fields: [posId], references: [id])
  saleItems SaleItem[]

  @@index([tenantId])
  @@index([posId])
  @@map("consignment_settlements")
}

model FinancialTransaction {
  id            String                 @id @default(uuid())
  tenantId      String
  type          TransactionType
  amount        Decimal                @db.Decimal(15, 2)
  referenceType FinancialReferenceType
  referenceId   String? // e.g. saleId
  description   String?
  createdAt     DateTime               @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([referenceId])
  @@index([createdAt])
  @@map("financial_transactions")
}

model OperationLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("operation_logs")
}

model WhatsAppConfig {
  id               String   @id @default(uuid())
  tenantId         String   @unique @map("tenant_id")
  instanceName     String   @map("instance_name")
  status           String   @default("disconnected")
  greetingMessage  String?  @map("greeting_message") @db.Text
  aiInstructions   String?  @map("ai_instructions") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("whatsapp_config")
}
